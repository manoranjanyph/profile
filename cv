<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Manoranjan Gouda | Marketing Portfolio</title>

    <!-- Google Fonts -->

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">

    <!-- Font Awesome -->

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <style>

        /* ============================= */
        /* GLOBAL RESET */
        /* ============================= */

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            scroll-behavior: smooth;
        }

        :root {

            --bg: #050505;
            --card: rgba(255, 255, 255, 0.03);

            --orange: #ff7a00;
            --gold: #ffb547;

            --white: #f5f5f5;
            --light: #d6d6d6;
            --gray: #9d9d9d;

            --shadowOrange: 0 0 40px rgba(255, 122, 0, 0.12);
        }

        body {

            font-family: 'Inter', sans-serif;
            color: var(--white);
            overflow-x: hidden;

            background:
                radial-gradient(circle at top left,
                    rgba(255, 122, 0, 0.12),
                    transparent 28%),

                radial-gradient(circle at bottom right,
                    rgba(255, 181, 71, 0.10),
                    transparent 30%),

                #050505;

            position: relative;
        }

        body::before {

            content: "";
            position: fixed;
            inset: 0;

            background-image:
                url("https://www.transparenttextures.com/patterns/asfalt-dark.png");

            opacity: 0.18;
            pointer-events: none;
            z-index: -1;
        }

        h1,
        h2,
        h3,
        h4,
        h5,
        h6 {

            font-family: 'Space Grotesk', sans-serif;
            letter-spacing: -1px;
        }

        p {
            line-height: 1.9;
            color: var(--light);
        }

        section {
            padding: 110px 8%;
            position: relative;
        }

        .container {
            max-width: 1400px;
            margin: auto;
        }

        /* ============================= */
        /* NAVBAR */
        /* ============================= */

        nav {

            position: fixed;
            top: 0;
            left: 0;
            width: 100%;

            z-index: 999;

            padding: 22px 8%;

            display: flex;
            justify-content: space-between;
            align-items: center;

            background: rgba(5, 5, 5, 0.72);
            backdrop-filter: blur(14px);

            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        }

        .logo {

            font-size: 28px;
            font-weight: 700;

            background: linear-gradient(to right,
                    var(--orange),
                    var(--gold));

            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-links {
            display: flex;
            gap: 36px;
        }

        .nav-links a {

            text-decoration: none;
            color: var(--white);

            font-size: 15px;
            font-weight: 500;

            position: relative;
            transition: .3s ease;
        }

        .nav-links a:hover {
            color: var(--orange);
        }

        .nav-links a::after {

            content: "";
            position: absolute;

            left: 0;
            bottom: -8px;

            width: 0%;
            height: 2px;

            background: linear-gradient(to right,
                    var(--orange),
                    var(--gold));

            transition: .3s ease;
        }

        .nav-links a:hover::after {
            width: 100%;
        }

        /* ============================= */
        /* HERO SECTION */
        /* ============================= */

        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            overflow: hidden;
        }

        .hero-wrapper {

            display: grid;
            grid-template-columns: 1.1fr .9fr;
            align-items: center;
            gap: 80px;

            position: relative;
            z-index: 2;
        }

        .hero-tag {

            display: inline-flex;
            align-items: center;
            gap: 10px;

            padding: 12px 22px;

            border-radius: 60px;

            border: 1px solid rgba(255, 122, 0, 0.22);

            background: rgba(255, 122, 0, 0.08);

            color: var(--orange);

            font-size: 14px;
            font-weight: 600;

            margin-bottom: 28px;
        }

        .hero h1 {

            font-size: 82px;
            line-height: 1.02;

            margin-bottom: 30px;

            letter-spacing: -3px;
        }

        .gradient {

            background: linear-gradient(to right,
                    var(--orange),
                    var(--gold));

            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero p {
            font-size: 20px;
            max-width: 760px;
            margin-bottom: 45px;
        }

        /* ============================= */
        /* BUTTONS */
        /* ============================= */

        .hero-btns {

            display: flex;
            align-items: center;
            gap: 18px;

            flex-wrap: wrap;

            margin-top: 10px;
        }

        .btn {

            position: relative;

            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;

            padding: 17px 34px;

            border-radius: 16px;

            font-size: 15px;
            font-weight: 600;

            text-decoration: none;

            transition: all .35s ease;

            overflow: hidden;

            cursor: pointer;

            border: none;

            isolation: isolate;
        }

        .btn-primary {

            background: linear-gradient(135deg,
                    var(--orange),
                    var(--gold));

            color: #ffffff;

            box-shadow:
                0 10px 35px rgba(255, 122, 0, 0.25);

            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .btn-primary::before {

            content: "";

            position: absolute;

            top: 0;
            left: -120%;

            width: 100%;
            height: 100%;

            background: linear-gradient(120deg,
                    transparent,
                    rgba(255, 255, 255, 0.22),
                    transparent);

            transition: .7s ease;

            z-index: -1;
        }

        .btn-primary:hover::before {
            left: 120%;
        }

        .btn-primary:hover {

            transform:
                translateY(-4px) scale(1.02);

            box-shadow:
                0 18px 50px rgba(255, 122, 0, 0.35);
        }

        .btn-secondary {

            background: rgba(255, 255, 255, 0.03);

            color: var(--white);

            border: 1px solid rgba(255, 255, 255, 0.08);

            backdrop-filter: blur(12px);

            box-shadow:
                inset 0 0 20px rgba(255, 255, 255, 0.02);
        }

        .btn-secondary:hover {

            transform:
                translateY(-4px);

            border-color:
                rgba(255, 122, 0, 0.25);

            background:
                rgba(255, 255, 255, 0.05);

            box-shadow:
                0 10px 40px rgba(255, 122, 0, 0.12);
        }

        /* ============================= */
        /* HERO HIGHLIGHTS */
        /* ============================= */

        .hero-highlights {

            display: grid;

            grid-template-columns:
                repeat(4, minmax(120px, 1fr));

            gap: 18px;

            margin-top: 50px;
        }

        .highlight-item {

            padding: 22px 20px;

            border-radius: 22px;

            background: linear-gradient(145deg,
                    rgba(255, 255, 255, 0.04),
                    rgba(255, 255, 255, 0.015));

            border: 1px solid rgba(255, 255, 255, 0.06);

            backdrop-filter: blur(10px);

            transition: .35s ease;
        }

        .highlight-item:hover {

            transform: translateY(-6px);

            border-color: rgba(255, 122, 0, 0.18);

            box-shadow:
                0 0 40px rgba(255, 122, 0, 0.10);
        }

        .highlight-item h3 {

            font-size: 34px;

            margin-bottom: 8px;

            background: linear-gradient(to right,
                    var(--orange),
                    var(--gold));

            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .highlight-item span {

            color: var(--gray);

            font-size: 14px;
        }

        /* ============================= */
        /* HERO IMAGE */
        /* ============================= */

        .hero-image-section {

            position: relative;

            display: flex;
            justify-content: center;
            align-items: center;
        }

        .hero-glow {

            position: absolute;

            width: 500px;
            height: 500px;

            border-radius: 50%;

            background:
                radial-gradient(circle,
                    rgba(255, 122, 0, 0.28),
                    rgba(255, 181, 71, 0.12),
                    transparent 70%);

            filter: blur(50px);

            z-index: 1;
        }

        .hero-image-card {

            position: relative;

            width: 430px;
            height: 540px;

            border-radius: 34px;

            overflow: hidden;

            z-index: 2;

            background: linear-gradient(145deg,
                    rgba(255, 255, 255, 0.06),
                    rgba(255, 255, 255, 0.02));

            border: 1px solid rgba(255, 255, 255, 0.08);

            backdrop-filter: blur(12px);

            box-shadow:
                0 0 50px rgba(255, 122, 0, 0.12);
        }

        .hero-image-card img {

            width: 100%;
            height: 100%;

            object-fit: cover;

            filter:
                contrast(1.05)
                brightness(0.95)
                saturate(1.05);
        }

        .hero-image-card::after {

            content: "";

            position: absolute;
            inset: 0;

            background:
                linear-gradient(to top,
                    rgba(0, 0, 0, 0.45),
                    rgba(0, 0, 0, 0.05));
        }

        /* ============================= */
        /* FLOATING CARDS */
        /* ============================= */

        .floating-card {

            position: absolute;

            padding: 14px 22px;

            border-radius: 18px;

            background: rgba(15, 15, 15, 0.82);

            backdrop-filter: blur(12px);

            border: 1px solid rgba(255, 255, 255, 0.08);

            color: var(--white);

            font-size: 14px;
            font-weight: 600;

            box-shadow:
                0 0 30px rgba(255, 122, 0, 0.10);

            z-index: 5;

            animation: float 4s ease-in-out infinite;
        }

        .card-1 {
            top: 40px;
            left: -40px;
        }

        .card-2 {
            top: 130px;
            right: -50px;
        }

        .card-3 {
            bottom: 120px;
            left: -60px;
        }

        .card-4 {
            bottom: 40px;
            right: -40px;
        }

        @keyframes float {

            0% {
                transform: translateY(0px);
            }

            50% {
                transform: translateY(-10px);
            }

            100% {
                transform: translateY(0px);
            }
        }

        /* ============================= */
        /* SECTION TITLES */
        /* ============================= */

        .section-title {

            font-size: 58px;
            line-height: 1.1;

            margin-bottom: 18px;
        }

        .section-subtitle {

            max-width: 820px;

            color: var(--gray);

            font-size: 17px;

            margin-bottom: 70px;
        }

        /* ============================= */
        /* PROJECTS */
        /* ============================= */

        .projects-grid {

            display: grid;

            grid-template-columns:
                repeat(auto-fit, minmax(350px, 1fr));

            gap: 32px;
        }

        .project-card {

            overflow: hidden;

            border-radius: 28px;

            background: linear-gradient(145deg,
                    rgba(255, 255, 255, 0.04),
                    rgba(255, 255, 255, 0.015));

            border: 1px solid rgba(255, 255, 255, 0.06);

            transition: .4s ease;
        }

        .project-card:hover {

            transform: translateY(-10px);

            box-shadow: var(--shadowOrange);

            border-color: rgba(255, 122, 0, 0.18);
        }

        .project-top {

            height: 5px;

            background: linear-gradient(to right,
                    var(--orange),
                    var(--gold));
        }

        .project-content {
            padding: 38px;
        }

        .project-tag {

            display: inline-block;

            padding: 8px 16px;

            border-radius: 40px;

            background: rgba(255, 122, 0, 0.08);

            color: var(--orange);

            font-size: 13px;
            font-weight: 600;

            margin-bottom: 22px;
        }

        .project-content h3 {

            font-size: 30px;

            margin-bottom: 18px;
        }

        .project-impact {

            margin-top: 22px;

            color: var(--gold);

            font-weight: 700;
        }

        footer {

            text-align: center;

            padding: 40px;

            color: #777;

            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        /* ============================= */
        /* RESPONSIVE */
        /* ============================= */

        @media(max-width: 1100px) {

            .hero-wrapper {

                grid-template-columns: 1fr;
                gap: 70px;
            }

            .hero-image-section {
                order: -1;
            }

            .hero-content {
                text-align: center;
            }

            .hero-btns {
                justify-content: center;
            }

            .hero-highlights {
                grid-template-columns:
                    repeat(2, 1fr);
            }
        }

        @media(max-width: 768px) {

            .hero-image-card {

                width: 320px;
                height: 420px;
            }

            .floating-card {
                display: none;
            }

            .hero h1 {
                font-size: 54px;
            }
        }

        @media(max-width: 600px) {

            section {
                padding: 90px 6%;
            }

            .hero h1 {

                font-size: 42px;
                line-height: 1.08;
            }

            .hero p {
                font-size: 17px;
            }

            .section-title {
                font-size: 38px;
            }

            .hero-btns {

                width: 100%;
                flex-direction: column;
            }

            .btn {
                width: 100%;
            }

            .hero-highlights {
                grid-template-columns: 1fr;
            }
        }

    </style>

</head>

